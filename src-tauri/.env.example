# Required environment variables for RUSA desktop application

# Supabase PostgreSQL direct connection string
# Use port 6543 for PgBouncer pooler in production
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:6543/postgres

# Redis connection URL (defaults to localhost if not set)
REDIS_URL=redis://127.0.0.1:6379

# Supabase Storage API URL
SUPABASE_STORAGE_URL=https://YOUR_PROJECT_REF.supabase.co/storage/v1

# Supabase service role key (NEVER expose to frontend)
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Supabase base project URL — used for Realtime WebSocket
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase anon (public) key — used for Realtime authentication
# Copy from: Supabase Dashboard → Settings → API → Project API keys → anon public
SUPABASE_ANON_KEY=your-anon-key-here
